# Fanoni PACS — copy this file to docker/.env and fill in the blanks.
# docker/.env is gitignored; never commit real credentials.

# Orthanc REST/DICOMweb credentials.
# The host nginx reverse proxy injects these so the public read-only viewer works;
# admins authenticate with them over an SSH tunnel. Use a long random password.
ORTHANC_USERNAME=fanoni
ORTHANC_PASSWORD=

# FHIR imaging-bridge-bot webhook, fired by notify_fhir.lua on OnStableStudy.
# Leave FANONI_BRIDGE_BOT_URL empty to disable the webhook entirely.
FANONI_BRIDGE_BOT_URL=http://host.docker.internal:8103/fhir/R4/Bot/imaging-bridge-bot/$execute
FANONI_BOT_TOKEN=

# Base URL the bridge bot should call back to reach this Orthanc (used in the webhook body).
FANONI_ORTHANC_BASE_URL=http://host.docker.internal:8042
